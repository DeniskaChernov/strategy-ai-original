{
  "name": "strategy-ai",
  "version": "1.1.0",
  "description": "Strategy AI — full-stack SaaS for strategic planning",
  "main": "server/index.js",
  "scripts": {
    "build:tailwind": "node ./node_modules/tailwindcss/lib/cli.js -i ./client/tailwind-input.css -o ./public/tailwind.css --minify",
    "build": "npm run build:tailwind && node build.js",
    "typecheck": "tsc --noEmit",
    "ci": "npm run build && tsc --noEmit && npm test && node scripts/verify-build-artifacts.js",
    "test": "vitest run",
    "test:strict-lib": "tsc --noEmit -p tsconfig.strict-lib.json",
    "test:e2e": "playwright test",
    "start": "node server/index.js",
    "sync:shell-css": "node scripts/gen-strategy-shell-css.js && node -e \"require('fs').copyFileSync('client/strategy-shell.css','public/strategy-shell.css')\"",
    "dev": "node scripts/sync-css.js && nodemon server/index.js",
    "seed": "node server/seed.js",
    "prepare": "node -e \"if (process.env.CI === 'true' || process.env.HUSKY === '0') process.exit(0); require('child_process').execSync('npx husky', {stdio:'inherit'})\"",
    "deploy": "git add -A && git status --short && (git diff --cached --quiet || (git commit -m \"chore: auto-deploy\" && git push))"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/node": "^8.55.0",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "gsap": "^3.14.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.7.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "postcss": "^8.5.9",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "stripe": "^15.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2"
}
