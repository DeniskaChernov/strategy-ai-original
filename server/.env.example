# ──────────────────────────────────────────────────────────────────────────
#  Strategy AI — production env
# ──────────────────────────────────────────────────────────────────────────
#  Скопируйте в server/.env (локально) или вставьте в Railway → Variables.
#  Подробнее: RAILWAY_DEPLOY.md, PAYMENT_INTEGRATION.md
# ──────────────────────────────────────────────────────────────────────────

# ── Database (Railway PostgreSQL — копируй из Railway > Variables) ─────────
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT (ОБЯЗАТЕЛЬНО в production!) ───────────────────────────────────────
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_RANDOM_64_BYTE_HEX_STRING

# Триальный период (дней) для нового пользователя
TRIAL_DAYS=7

# ── Dev-аккаунт (НЕ задавать в production!) ───────────────────────────────
# Через запятую: список email'ов, у которых tier меняется без оплаты.
# В production оставить пустым.
DEV_EMAILS=

# (опционально) автосоздание seed-пользователя при старте
DEV_EMAIL=
DEV_PASSWORD=
DEV_NAME=
DEV_TIER=

# ── Мониторинг ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Email (Resend — бесплатно 3000 писем/мес) ─────────────────────────────
# Получи API ключ на https://resend.com
RESEND_API_KEY=re_REPLACE_ME
FROM_EMAIL=noreply@yourdomain.com

# ── CORS (домен фронтенда, через запятую) ─────────────────────────────────
ALLOWED_ORIGINS=https://www.strategy-ai.uz,https://strategy-ai.uz

# ── App URL (используется в Stripe redirect URLs и письмах) ───────────────
APP_URL=https://strategy-ai.uz

# ── OpenAI (имя переменной в Railway: OPENAI_KEY) ─────────────────────────
# Получи на https://platform.openai.com/api-keys
OPENAI_KEY=sk-REPLACE_ME

# ── Stripe ────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# Webhook secret — Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Price IDs (создай продукты в Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_TEAM=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME

# (опционально) сколько дней хранить stripe_webhook_events для идемпотентности
# По умолчанию 90, мин 30, макс 365
# STRIPE_WEBHOOK_EVENTS_RETENTION_DAYS=90

# ── SEO ───────────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://strategy-ai.uz

# ── Web Push (опционально) ────────────────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# REQUIRE_EMAIL_VERIFIED_FOR_AI=true
